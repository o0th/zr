const HeadlineProps = struct {
	headline: zr.Headline,
};

pub fn Headline(allocator: zx.Allocator, props: HeadlineProps) zx.Component {
    return (
        <div @allocator={allocator}>
			{if (props.headline.show) (
				<>
					{if (props.headline.name) |name| (
						<p class="text-xl">{name}</p>
					)}
					{if (props.headline.title) |title| (
						<p class="text-md">{title}</p>
					)}
				</>
			)}
        </div>
    );
}

const zx = @import("zx");
const zr = @import("../zr.zig");
